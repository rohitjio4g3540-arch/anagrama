GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Used automatically only if Gemini rejects the configured model as unavailable.
GEMINI_FALLBACK_MODEL=gemini-3.5-flash
DATABASE_URL=postgresql+psycopg://anagrama:anagrama@localhost:5432/anagrama
POSTGRES_URL=postgresql://anagrama:anagrama@localhost:5432/anagrama
VECTOR_DB_URL=postgresql://anagrama:anagrama@localhost:5432/anagrama
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
ANAGRAMA_STORAGE_PATH=storage/uploads
NEXT_PUBLIC_API_URL=http://localhost:8000
